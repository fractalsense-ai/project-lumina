{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://projectlumina.org/standards/student-profile-schema-v1.json",
  "title": "Student Profile Schema V1",
  "description": "JSON Schema for Project Lumina student profiles. Preferences are used for immersion only and must never influence grading or mastery assessment.",
  "type": "object",
  "required": [
    "student_id",
    "domain_id",
    "learning_state"
  ],
  "additionalProperties": false,
  "properties": {
    "student_id": {
      "type": "string",
      "description": "Pseudonymous student identifier"
    },
    "domain_id": {
      "type": "string",
      "description": "Domain pack ID this profile is associated with"
    },
    "display_name": {
      "type": "string",
      "description": "Optional display name (may be a nickname, not necessarily real name)"
    },
    "preferences": {
      "$ref": "#/$defs/preferences",
      "description": "Student interests and dislikes. Used for immersion (e.g., themed problems) ONLY. Must never influence grading or mastery."
    },
    "learning_state": {
      "$ref": "#/$defs/learning_state",
      "description": "Current compressed learning state"
    },
    "session_history": {
      "type": "object",
      "properties": {
        "total_sessions": { "type": "integer", "minimum": 0 },
        "last_session_utc": { "type": ["string", "null"] },
        "total_turns": { "type": "integer", "minimum": 0 }
      },
      "description": "Aggregate session metadata (no transcripts)"
    },
    "consent": {
      "$ref": "#/$defs/consent_record",
      "description": "Magic circle consent record"
    },
    "updated_utc": {
      "type": "string",
      "description": "ISO-8601 timestamp of last profile update"
    }
  },
  "$defs": {
    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "interests": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Topics/themes the student enjoys (e.g., space, soccer, cooking). Used for example generation only."
        },
        "dislikes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Topics/themes to avoid in examples"
        },
        "preferred_explanation_style": {
          "type": "string",
          "enum": ["step_by_step", "visual_analogy", "direct", "socratic"],
          "description": "Preferred pedagogical style (informational only; orchestrator may adapt)"
        },
        "language": {
          "type": "string",
          "description": "Preferred language code (e.g., 'en', 'es')"
        }
      }
    },
    "learning_state": {
      "type": "object",
      "required": ["affect", "mastery", "zpd_band", "recent_window"],
      "additionalProperties": false,
      "properties": {
        "affect": {
          "$ref": "#/$defs/affect_state"
        },
        "mastery": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "description": "Per-skill mastery estimates (0..1)"
        },
        "zpd_band": {
          "type": "object",
          "required": ["min_challenge", "max_challenge"],
          "additionalProperties": false,
          "properties": {
            "min_challenge": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "max_challenge": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "recent_window": {
          "$ref": "#/$defs/recent_window"
        },
        "challenge": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Estimated challenge level of current task (0..1)"
        },
        "uncertainty": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Orchestrator uncertainty about learner state (0..1)"
        },
        "updated_utc": {
          "type": "string",
          "description": "ISO-8601 timestamp of last state update"
        }
      }
    },
    "affect_state": {
      "type": "object",
      "required": ["salience", "valence", "arousal"],
      "additionalProperties": false,
      "properties": {
        "salience": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Engagement/focus level (0=disengaged, 1=highly focused)"
        },
        "valence": {
          "type": "number",
          "minimum": -1,
          "maximum": 1,
          "description": "Emotional tone (-1=negative, 0=neutral, +1=positive)"
        },
        "arousal": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Activation level (0=flat, 1=highly activated)"
        }
      }
    },
    "recent_window": {
      "type": "object",
      "required": ["window_turns"],
      "additionalProperties": false,
      "properties": {
        "window_turns": {
          "type": "integer",
          "minimum": 1,
          "description": "Size of the rolling window"
        },
        "attempts": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of task attempts in the window"
        },
        "consecutive_incorrect": {
          "type": "integer",
          "minimum": 0,
          "description": "Consecutive incorrect responses"
        },
        "hint_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of hints used in the window"
        },
        "outside_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Fraction of turns where challenge was outside ZPD band"
        },
        "consecutive_outside": {
          "type": "integer",
          "minimum": 0,
          "description": "Consecutive turns where challenge was outside ZPD band"
        }
      }
    },
    "consent_record": {
      "type": "object",
      "required": ["magic_circle_accepted", "consent_timestamp_utc"],
      "additionalProperties": false,
      "properties": {
        "magic_circle_accepted": {
          "type": "boolean",
          "description": "Whether the student has accepted the magic circle consent contract"
        },
        "consent_timestamp_utc": {
          "type": "string",
          "description": "ISO-8601 timestamp of consent"
        },
        "consent_version": {
          "type": "string",
          "description": "Version of the magic circle consent contract accepted"
        },
        "guardian_consent": {
          "type": "boolean",
          "description": "Whether guardian/parental consent has been obtained (for minors)"
        }
      }
    }
  }
}
