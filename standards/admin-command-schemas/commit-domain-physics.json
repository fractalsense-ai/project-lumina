{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lumina://standards/admin-command-schemas/commit-domain-physics.json",
  "title": "commit_domain_physics",
  "description": "Commit pending domain physics changes for a given domain, writing a CTL commitment record.",
  "type": "object",
  "required": ["operation", "params"],
  "additionalProperties": false,
  "properties": {
    "operation": { "const": "commit_domain_physics" },
    "target": { "type": "string" },
    "params": {
      "type": "object",
      "required": ["domain_id"],
      "additionalProperties": false,
      "properties": {
        "domain_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
