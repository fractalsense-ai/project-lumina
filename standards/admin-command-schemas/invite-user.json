{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lumina://standards/admin-command-schemas/invite-user.json",
  "schema_version": "1.0.0",
  "last_updated": "2026-03-20",
  "title": "invite_user",
  "description": "Invite a new user to the platform with a specified role.",
  "type": "object",
  "required": [
    "operation",
    "params"
  ],
  "additionalProperties": false,
  "properties": {
    "operation": {
      "const": "invite_user"
    },
    "target": {
      "type": "string"
    },
    "params": {
      "type": "object",
      "required": [
        "username",
        "role"
      ],
      "additionalProperties": false,
      "properties": {
        "username": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "root",
            "domain_authority",
            "it_support",
            "qa",
            "auditor",
            "user",
            "guest"
          ]
        },
        "governed_modules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Module IDs the new domain_authority may govern."
        },
        "intended_domain_role": {
          "type": "string",
          "description": "Original domain-specific role from SLM output (e.g. student, teacher) before mapping to system role."
        },
        "domain_id": {
          "type": "string",
          "description": "Target domain identifier (e.g. education, agriculture). Used to auto-resolve governed_modules and pre-assign domain roles."
        },
        "email": {
          "type": "string",
          "description": "Email address for sending the invite link."
        }
      }
    }
  }
}
