{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lumina://standards/admin-command-schemas/update-domain-physics.json",
  "title": "update_domain_physics",
  "description": "Update domain physics fields for a given domain. The updates object contains domain-physics keys to modify.",
  "type": "object",
  "required": ["operation", "params"],
  "additionalProperties": false,
  "properties": {
    "operation": { "const": "update_domain_physics" },
    "target": { "type": "string", "description": "Alias for domain_id (backward compat)." },
    "params": {
      "type": "object",
      "required": ["domain_id", "updates"],
      "additionalProperties": false,
      "properties": {
        "domain_id": { "type": "string", "minLength": 1 },
        "updates": { "type": "object", "description": "Key-value pairs to merge into domain physics." }
      }
    }
  }
}
