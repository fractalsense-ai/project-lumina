        "description": "Operating signal should remain within configured tolerance.",
        "severity": "warning"
      }
    },
    "invariant:agriculture:sensor_reading_valid": {
      "node_id": "invariant:agriculture:sensor_reading_valid",
      "label": "sensor_reading_valid",
      "kind": "invariant",
      "domain_id": "agriculture",
      "detail": {
        "description": "Collar sensor reading must pass normalization without error. A failed normalization indicates hardware fault or corrupt data.",
        "severity": "critical"
      }
    },
    "invariant:agriculture:signal_within_operational_range": {
      "node_id": "invariant:agriculture:signal_within_operational_range",
      "label": "signal_within_operational_range",
      "kind": "invariant",
      "domain_id": "agriculture",
      "detail": {
        "description": "Composite signal index must stay within the operational band (0.2..0.9). Values outside this range indicate sensor drift or environmental anomaly.",
        "severity": "critical"
      }
    },
    "invariant:agriculture:drift_minor": {
      "node_id": "invariant:agriculture:drift_minor",
      "label": "drift_minor",
      "kind": "invariant",
      "domain_id": "agriculture",
      "detail": {
        "description": "Signal has drifted outside tolerance for >= 30% of the recent monitoring window.",
        "severity": "warning"
      }
    },
    "invariant:agriculture:drift_major": {
      "node_id": "invariant:agriculture:drift_major",
      "label": "drift_major",
      "kind": "invariant",
      "domain_id": "agriculture",
      "detail": {
        "description": "Signal outside tolerance for >= 50% of recent window or 3+ consecutive turns. Requires intervention.",
        "severity": "warning"
      }
    },
    "standing_order:agriculture:request_more_steps": {
      "node_id": "standing_order:agriculture:request_more_steps",
      "label": "request_more_steps",
      "kind": "standing_order",
      "domain_id": "agriculture",
      "detail": {
        "description": "Request additional operational details from the subject."
      }
    },
    "standing_order:agriculture:request_sensor_recheck": {
      "node_id": "standing_order:agriculture:request_sensor_recheck",
      "label": "request_sensor_recheck",
      "kind": "standing_order",
      "domain_id": "agriculture",
      "detail": {
        "description": "Request the operator to re-read the collar sensor. If re-read also fails, escalate to site manager for hardware inspection."
      }
    },
    "standing_order:agriculture:alert_site_manager": {
      "node_id": "standing_order:agriculture:alert_site_manager",
      "label": "alert_site_manager",
      "kind": "standing_order",
      "domain_id": "agriculture",
      "detail": {
        "description": "Notify the site manager that the signal has exceeded operational bounds. Pause data collection until the anomaly is resolved."
      }
    },
    "glossary:system:ctl": {
      "node_id": "glossary:system:ctl",
      "label": "ctl",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "System Logs — the append-only, hash-chained record of all domain-session trace events and commitment records.",
        "aliases": []
      }
    },
    "glossary:system:commitment_record": {
      "node_id": "glossary:system:commitment_record",
      "label": "commitment_record",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "A System Log record that marks a durable system decision: domain-physics activation, role change, escalation, or daemon batch outcome.",
        "aliases": []
      }
    },
    "glossary:system:trace_event": {
      "node_id": "glossary:system:trace_event",
      "label": "trace_event",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "A single LLM-driven turn record in the System Logs, capturing input evidence, state delta, and the system-physics hash active at the time.",
        "aliases": []
      }
    },
    "glossary:system:system_physics": {
      "node_id": "glossary:system:system_physics",
      "label": "system_physics",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "The machine-readable global invariant layer (cfg/system-physics.yaml / .json) that constrains every domain session regardless of which domain is active.",
        "aliases": []
      }
    },
    "glossary:system:domain_physics": {
      "node_id": "glossary:system:domain_physics",
      "label": "domain_physics",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "A domain-pack JSON file defining the module's topics, glossary, standing orders, escalation conditions, and artifacts.",
        "aliases": []
      }
    },
    "glossary:system:domain_pack": {
      "node_id": "glossary:system:domain_pack",
      "label": "domain_pack",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "A self-contained module bundle (cfg, prompts, domain-lib, controllers, modules) that implants a domain into the Lumina runtime.",
        "aliases": []
      }
    },
    "glossary:system:domain_authority": {
      "node_id": "glossary:system:domain_authority",
      "label": "domain_authority",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "A role with authoring rights over one or more governed modules; highest ceiling for domain-scoped operations.",
        "aliases": []
      }
    },
    "glossary:system:meta_authority": {
      "node_id": "glossary:system:meta_authority",
      "label": "meta_authority",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "The cross-domain governance layer above a Domain Authority; approves cross-domain synthesis and standing-order conflicts.",
        "aliases": []
      }
    },
    "glossary:system:policy_gate": {
      "node_id": "glossary:system:policy_gate",
      "label": "policy_gate",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "A hard invariant in system physics that cannot be overridden by any domain pack; violated by a session → escalation.",
        "aliases": []
      }
    },
    "glossary:system:hash_chain": {
      "node_id": "glossary:system:hash_chain",
      "label": "hash_chain",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "The linked sequence of record_hash values in the System Logs that provides tamper-evidence across all ledger entries.",
        "aliases": []
      }
    },
    "glossary:system:rbac": {
      "node_id": "glossary:system:rbac",
      "label": "rbac",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "Role-Based Access Control — Lumina's permission model combining chmod-style octal modes with optional extended ACLs.",
        "aliases": []
      }
    },
    "glossary:system:domain_registry": {
      "node_id": "glossary:system:domain_registry",
      "label": "domain_registry",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "cfg/domain-registry.yaml — the file that maps domain_id keys to their runtime-config paths and routing metadata.",
        "aliases": []
      }
    },
    "glossary:system:standing_order": {
      "node_id": "glossary:system:standing_order",
      "label": "standing_order",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "A persistent instruction authored by a Domain Authority that survives across session turns until explicitly revoked.",
        "aliases": []
      }
    },
    "glossary:system:escalation": {
      "node_id": "glossary:system:escalation",
      "label": "escalation",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "A domain-session signal that exceeds a policy-gate threshold; surfaces to Meta Authority and writes an escalation record to the System Logs.",
        "aliases": []
      }
    },
    "glossary:system:daemon_batch": {
      "node_id": "glossary:system:daemon_batch",
      "label": "daemon_batch",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "A load-based batch processing subsystem that performs glossary expansion, constraint refresh, and knowledge-graph rebuilds for a domain. Supersedes the former night cycle.",
        "aliases": []
      }
    },
    "glossary:system:tool_adapter": {
      "node_id": "glossary:system:tool_adapter",
      "label": "tool_adapter",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "A domain-pack module that exposes a callable to the Lumina orchestrator as a named tool during a session.",
        "aliases": []
      }
    },
    "glossary:system:domain_lib": {
      "node_id": "glossary:system:domain_lib",
      "label": "domain_lib",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "A domain-pack library of pure functions available to controller adapters without LLM involvement.",
        "aliases": []
      }
    },
    "glossary:system:pseudonymous_id": {
      "node_id": "glossary:system:pseudonymous_id",
      "label": "pseudonymous_id",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "The opaque, non-reversible identifier stored in the System Logs in place of a real user identifier.",
        "aliases": []
      }
    },
    "glossary:system:ingestion_pipeline": {
      "node_id": "glossary:system:ingestion_pipeline",
      "label": "ingestion_pipeline",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "The upload → extract → SLM-interpret → DA-review → commit workflow for importing external content into a domain pack.",
        "aliases": []
      }
    },
    "glossary:system:governed_modules": {
      "node_id": "glossary:system:governed_modules",
      "label": "governed_modules",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "The list of module IDs (e.g. domain/edu/algebra-level-1/v1) that a domain_authority has authoring and approval rights over.  Required at invite time; cannot be empty for the domain_authority role.",
        "aliases": []
      }
    },
    "glossary:system:invite_token": {
      "node_id": "glossary:system:invite_token",
      "label": "invite_token",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "A single-use, URL-safe token generated when an admin invites a new user.  Embedded in the setup_url; consumed by POST /api/auth/setup-password to activate the account.  Expires after LUMINA_INVITE_TOKEN_TTL_SECONDS (default 24 h).",
        "aliases": []
      }
    },
    "glossary:system:pending_user": {
      "node_id": "glossary:system:pending_user",
      "label": "pending_user",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "A user account that has been created by invitation but not yet activated.  active=false, password_hash is empty.  Cannot log in until POST /api/auth/setup-password is called with a valid invite_token.",
        "aliases": []
      }
    },
    "glossary:system:user_management_sop": {
      "node_id": "glossary:system:user_management_sop",
      "label": "user_management_sop",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "The standing order defining the invite → setup-link → password-set → active account workflow.  Ensures passwords are never transmitted over the admin interface.",
        "aliases": []
      }
    },
    "glossary:system:domain_authority_onboarding_sop": {
      "node_id": "glossary:system:domain_authority_onboarding_sop",
      "label": "domain_authority_onboarding_sop",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "The standing order for creating domain_authority accounts with explicit governed_modules definitions before the invite is issued.",
        "aliases": []
      }
    },
    "glossary:system:escalation_review_sop": {
      "node_id": "glossary:system:escalation_review_sop",
      "label": "escalation_review_sop",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "The standing order for reviewing, resolving, and optionally PIN-unlocking sessions tied to open escalation events.",
        "aliases": []
      }
    },
    "glossary:system:domain_role": {
      "node_id": "glossary:system:domain_role",
      "label": "domain_role",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "A role defined in a module's domain-physics.json (e.g. student, teacher, parent) that is scoped to that domain.  Domain roles are not system roles; they map to the system role 'user' via maps_to_system_role.  Domain roles carry module-specific capabilities and access levels.",
        "aliases": []
      }
    },
    "glossary:system:system_role": {
      "node_id": "glossary:system:system_role",
      "label": "system_role",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "One of the seven RBAC roles recognised by the Lumina kernel: root, domain_authority, it_support, qa, auditor, user, guest.  System roles are stored in the user record and govern API-level access.  Domain roles are assigned separately within a module context.",
        "aliases": []
      }
    },
    "glossary:system:intended_domain_role": {
      "node_id": "glossary:system:intended_domain_role",
      "label": "intended_domain_role",
      "kind": "glossary_term",
      "domain_id": "system",
      "detail": {
        "definition": "An advisory field set during SLM command normalisation when the user requests a domain-specific role (e.g. 'student').  The system role is set to 'user' and the original domain role name is preserved in this field for downstream domain-role assignment.",
        "aliases": []
      }
    },
