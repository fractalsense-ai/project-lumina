{
  "nodes": {
    "glossary:education:variable": {
      "node_id": "glossary:education:variable",
      "label": "variable",
      "kind": "glossary_term",
      "domain_id": "education",
      "detail": {
        "definition": "A letter (like x or y) that represents an unknown number you are trying to find.",
        "aliases": [
          "variables",
          "unknown",
          "unknowns",
          "the letter"
        ]
      }
    },
    "glossary:education:expression": {
      "node_id": "glossary:education:expression",
      "label": "expression",
      "kind": "glossary_term",
      "domain_id": "education",
      "detail": {
        "definition": "A combination of numbers, variables, and operations that does NOT have an equals sign. It has a value but is not a complete statement.",
        "aliases": [
          "expressions",
          "algebraic expression",
          "math expression"
        ]
      }
    },
    "glossary:education:order of operations": {
      "node_id": "glossary:education:order of operations",
      "label": "order of operations",
      "kind": "glossary_term",
      "domain_id": "education",
      "detail": {
        "definition": "The rule that dictates the sequence for evaluating an expression: Parentheses, Exponents, Multiplication and Division (left to right), Addition and Subtraction (left to right). PEMDAS.",
        "aliases": [
          "PEMDAS",
          "BODMAS",
          "order of ops"
        ]
      }
    },
    "glossary:education:inverse operation": {
      "node_id": "glossary:education:inverse operation",
      "label": "inverse operation",
      "kind": "glossary_term",
      "domain_id": "education",
      "detail": {
        "definition": "The opposite operation that undoes another. Addition and subtraction are inverses. Multiplication and division are inverses. To isolate x, apply inverse operations in the reverse order they were applied.",
        "aliases": [
          "inverse operations",
          "opposite operation",
          "undo operation"
        ]
      }
    },
    "glossary:education:isolate": {
      "node_id": "glossary:education:isolate",
      "label": "isolate",
      "kind": "glossary_term",
      "domain_id": "education",
      "detail": {
        "definition": "To get the variable alone on one side of the equation by performing inverse operations on both sides.",
        "aliases": [
          "isolating the variable",
          "get x alone",
          "solve for x"
        ]
      }
    },
    "glossary:education:inequality": {
      "node_id": "glossary:education:inequality",
      "label": "inequality",
      "kind": "glossary_term",
      "domain_id": "education",
      "detail": {
        "definition": "A mathematical statement that two expressions are not equal, using <, >, ≤, or ≥. The solution is usually a range of values, not a single number.",
        "aliases": [
          "inequalities",
          "inequality statement",
          "inequality sign"
        ]
      }
    },
    "glossary:education:inequality direction flip": {
      "node_id": "glossary:education:inequality direction flip",
      "label": "inequality direction flip",
      "kind": "glossary_term",
      "domain_id": "education",
      "detail": {
        "definition": "When both sides of an inequality are multiplied or divided by a negative number, the inequality sign must reverse direction.",
        "aliases": [
          "flip the sign",
          "reverse the inequality",
          "flip rule"
        ]
      }
    },
    "glossary:education:coefficient": {
      "node_id": "glossary:education:coefficient",
      "label": "coefficient",
      "kind": "glossary_term",
      "domain_id": "education",
      "detail": {
        "definition": "The number multiplied directly by a variable. When no number is written, the coefficient is 1.",
        "aliases": [
          "coefficients",
          "the number in front of x"
        ]
      }
    },
    "glossary:education:constant": {
      "node_id": "glossary:education:constant",
      "label": "constant",
      "kind": "glossary_term",
      "domain_id": "education",
      "detail": {
        "definition": "A number on its own that does not change and is not attached to a variable.",
        "aliases": [
          "constants",
          "plain number",
          "fixed number"
        ]
      }
    },
    "invariant:education:equivalence_preserved": {
      "node_id": "invariant:education:equivalence_preserved",
      "label": "equivalence_preserved",
      "kind": "invariant",
      "domain_id": "education",
      "detail": {
        "description": "Law 1 (Balance Principle): both sides of an equation must remain algebraically equal after every transformation step. Applying an operation to only one side is the canonical Law 1 failure.\n",
        "severity": "critical"
      }
    },
    "invariant:education:no_illegal_operations": {
      "node_id": "invariant:education:no_illegal_operations",
      "label": "no_illegal_operations",
      "kind": "invariant",
      "domain_id": "education",
      "detail": {
        "description": "Division by zero, taking a square root of a negative number (outside imaginary number context), or applying any undefined operation is not permitted.\n",
        "severity": "critical"
      }
    },
    "invariant:education:solution_verifies": {
      "node_id": "invariant:education:solution_verifies",
      "label": "solution_verifies",
      "kind": "invariant",
      "domain_id": "education",
      "detail": {
        "description": "The proposed solution must satisfy the original equation or inequality when substituted back in. Active from artifact single_step_equations onward.\n",
        "severity": "critical"
      }
    },
    "invariant:education:inequality_direction_preserved": {
      "node_id": "invariant:education:inequality_direction_preserved",
      "label": "inequality_direction_preserved",
      "kind": "invariant",
      "domain_id": "education",
      "detail": {
        "description": "When multiplying or dividing both sides of an inequality by a negative number, the inequality sign must flip direction. This is the critical direction-flip rule and the primary advanced diagnostic signal in this module.\n",
        "severity": "critical"
      }
    },
    "invariant:education:reversibility_order_correct": {
      "node_id": "invariant:education:reversibility_order_correct",
      "label": "reversibility_order_correct",
      "kind": "invariant",
      "domain_id": "education",
      "detail": {
        "description": "Law 2 (Inverse Operations): to undo a multi-step expression the student must reverse the order of operations — PEMDAS in reverse. Attempting to divide by a coefficient before eliminating an added constant is the canonical failure signal. NOTE: this invariant requires evidence field 'reversibility_order_correct', currently estimated by the LLM interpreter; deterministic tool_adapter support is planned for module v0.2.\n",
        "severity": "warning"
      }
    },
    "invariant:education:standard_method_preferred": {
      "node_id": "invariant:education:standard_method_preferred",
      "label": "standard_method_preferred",
      "kind": "invariant",
      "domain_id": "education",
      "detail": {
        "description": "Non-standard solution methods are acceptable but should be flagged for Domain Authority review.\n",
        "severity": "warning"
      }
    },
    "invariant:education:show_work_minimum": {
      "node_id": "invariant:education:show_work_minimum",
      "label": "show_work_minimum",
      "kind": "invariant",
      "domain_id": "education",
      "detail": {
        "description": "Solutions must show at least the minimum number of distinct transformation steps required by the problem type. A bare answer with no work shown is not acceptable.\n",
        "severity": "warning"
      }
    },
    "invariant:education:zpd_drift_minor": {
      "node_id": "invariant:education:zpd_drift_minor",
      "label": "zpd_drift_minor",
      "kind": "invariant",
      "domain_id": "education",
      "detail": {
        "description": "The student's challenge level has drifted outside the ZPD band in >= 30% of the recent window turns.\n",
        "severity": "warning"
      }
    },
    "invariant:education:zpd_drift_major": {
      "node_id": "invariant:education:zpd_drift_major",
      "label": "zpd_drift_major",
      "kind": "invariant",
      "domain_id": "education",
      "detail": {
        "description": "The student's challenge level has drifted outside the ZPD band in >= 50% of recent window turns, or for 3+ consecutive turns.\n",
        "severity": "warning"
      }
    },
    "invariant:education:fluency_bottleneck": {
      "node_id": "invariant:education:fluency_bottleneck",
      "label": "fluency_bottleneck",
      "kind": "invariant",
      "domain_id": "education",
      "detail": {
        "description": "The student is solving equations correctly but consistently exceeding the time threshold, indicating procedural automaticity has not been achieved at the current tier.\n",
        "severity": "warning"
      }
    },
    "standing_order:education:request_more_steps": {
      "node_id": "standing_order:education:request_more_steps",
      "label": "request_more_steps",
      "kind": "standing_order",
      "domain_id": "education",
      "detail": {
        "description": "Ask the student to show their work step by step, identifying each transformation they applied to both sides of the equation.\n"
      }
    },
    "standing_order:education:request_verification_retry": {
      "node_id": "standing_order:education:request_verification_retry",
      "label": "request_verification_retry",
      "kind": "standing_order",
      "domain_id": "education",
      "detail": {
        "description": "Ask the student to substitute their answer back into the original equation or inequality and confirm both sides balance.\n"
      }
    },
    "standing_order:education:request_inequality_direction_correction": {
      "node_id": "standing_order:education:request_inequality_direction_correction",
      "label": "request_inequality_direction_correction",
      "kind": "standing_order",
      "domain_id": "education",
      "detail": {
        "description": "Prompt the student to re-examine the step where they divided or multiplied by a negative number and ask which direction the inequality sign should point. Do not state the flip rule directly on the first prompt.\n"
      }
    },
    "standing_order:education:hint_reverse_order_of_operations": {
      "node_id": "standing_order:education:hint_reverse_order_of_operations",
      "label": "hint_reverse_order_of_operations",
      "kind": "standing_order",
      "domain_id": "education",
      "detail": {
        "description": "Provide the Law 2 scaffolding: ask the student to list the operations applied to x in order, then ask them to undo those operations starting from the last one. Do not solve the problem.\n"
      }
    },
    "standing_order:education:request_method_justification": {
      "node_id": "standing_order:education:request_method_justification",
      "label": "request_method_justification",
      "kind": "standing_order",
      "domain_id": "education",
      "detail": {
        "description": "Acknowledge the non-standard approach and ask the student to explain their reasoning. Flag for Domain Authority review.\n"
      }
    },
    "standing_order:education:zpd_scaffold": {
      "node_id": "standing_order:education:zpd_scaffold",
      "label": "zpd_scaffold",
      "kind": "standing_order",
      "domain_id": "education",
      "detail": {
        "description": "Reduce challenge level on the next task. Offer an optional hint. Provide additional scaffolding in the explanation.\n"
      }
    },
    "standing_order:education:zpd_intervene_or_escalate": {
      "node_id": "standing_order:education:zpd_intervene_or_escalate",
      "label": "zpd_intervene_or_escalate",
      "kind": "standing_order",
      "domain_id": "education",
      "detail": {
        "description": "Pause the current task. Issue one probe question to check understanding. If the probe response does not improve state, escalate to teacher.\n"
      }
    },
    "standing_order:education:trigger_targeted_hint": {
      "node_id": "standing_order:education:trigger_targeted_hint",
      "label": "trigger_targeted_hint",
      "kind": "standing_order",
      "domain_id": "education",
      "detail": {
        "description": "Provide a targeted procedural hint for the specific step the student is slowing on. Do not solve the problem.\n"
      }
    },
    "invariant:agriculture:within_tolerance": {
      "node_id": "invariant:agriculture:within_tolerance",
      "label": "within_tolerance",
      "kind": "invariant",
      "domain_id": "agriculture",
