# Project Lumina environment template
# Copy to .env for local development only. Never commit real secrets.

# Required: runtime config (choose ONE)
# Single-domain mode:
LUMINA_RUNTIME_CONFIG_PATH=domain-packs/education/runtime-config.yaml
# Multi-domain mode (comment out RUNTIME_CONFIG_PATH and uncomment below):
# LUMINA_DOMAIN_REGISTRY_PATH=domain-registry.yaml

# ── Primary LLM provider ──────────────────────────────
# Provider: local | openai | anthropic | google | azure | mistral
#   Leave unset for deterministic mode (no LLM).
LUMINA_LLM_PROVIDER=local
LUMINA_LLM_ENDPOINT=http://localhost:11434
LUMINA_LLM_MODEL=llama3
LUMINA_LLM_TIMEOUT=120

# Cloud provider model overrides (only read when using that provider)
LUMINA_OPENAI_MODEL=gpt-4o
LUMINA_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Provider API keys (set only the one matching LUMINA_LLM_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# AZURE_OPENAI_API_KEY=
# LUMINA_AZURE_OPENAI_ENDPOINT=
# LUMINA_AZURE_OPENAI_DEPLOYMENT=
# MISTRAL_API_KEY=

# ── SLM (Small Language Model) layer ──────────────────
# Provider: local | openai | anthropic
LUMINA_SLM_PROVIDER=local
LUMINA_SLM_MODEL=gemma3:4b
LUMINA_SLM_ENDPOINT=http://localhost:11434
LUMINA_SLM_TIMEOUT=60

# ── JWT authentication ────────────────────────────────
# Development: set only LUMINA_JWT_SECRET (single shared secret).
# Production: set LUMINA_ADMIN_JWT_SECRET + LUMINA_USER_JWT_SECRET
#   for dual-secret JWT architecture (admin/user tier separation).
LUMINA_JWT_SECRET=
LUMINA_JWT_TTL_MINUTES=60
LUMINA_JWT_ALGORITHM=HS256
# LUMINA_ADMIN_JWT_SECRET=
# LUMINA_USER_JWT_SECRET=

# ── Transcript seal (chat persistence) ────────────────
# Uses LUMINA_JWT_SECRET as the HMAC key by default.
# Override with a dedicated key if desired:
# LUMINA_TRANSCRIPT_HMAC_SECRET=

# ── Password hashing ─────────────────────────────────
# Algorithm: argon2id (default) | bcrypt | sha256
# Requires [passwords] extra for argon2id/bcrypt.
LUMINA_PASSWORD_HASH_ALGORITHM=argon2id

# ── Persistence and runtime ───────────────────────────
LUMINA_PERSISTENCE_BACKEND=filesystem
LUMINA_DB_URL=sqlite+aiosqlite:///lumina.db
LUMINA_ENFORCE_POLICY_COMMITMENT=true
LUMINA_BOOTSTRAP_MODE=false

# ── System Log directory ──────────────────────────────
# Required in production. Falls back to a temp directory if unset.
# LUMINA_LOG_DIR=

# ── Server ────────────────────────────────────────────
LUMINA_PORT=8000
LUMINA_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
