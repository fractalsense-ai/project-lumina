{
  "id": "domain/agriculture/operations-level-1/v1",
  "version": "0.1.0",
  "domain_authority": {
    "name": "Lead Operations Manager",
    "role": "DomainAuthority",
    "pseudonymous_id": "da_agri_ops_001"
  },
  "meta_authority_id": "domain/agriculture/meta/v1",
  "description": "Agriculture operations level 1 demo domain pack.",
  "department": "Field Operations",
  "lumina_core_version": "1.0.0",
  "invariants": [
    {
      "id": "within_tolerance",
      "description": "Operating signal should remain within configured tolerance.",
      "severity": "warning",
      "check": "within_tolerance",
      "standing_order_on_violation": "request_more_steps"
    }
  ],
  "standing_orders": [
    {
      "id": "request_more_steps",
      "action": "request_more_steps",
      "trigger_condition": "within_tolerance",
      "max_attempts": 2,
      "escalation_on_exhaust": false,
      "description": "Request additional operational details from the subject."
    }
  ],
  "escalation_triggers": [],
  "artifacts": [],
  "subsystem_configs": {
    "ops_monitor": {
      "window_turns": 5,
      "drift_threshold": 0.4
    }
  },
  "evidence_schema": {
    "path": "evidence-schema.json",
    "version": "1.0"
  },
  "tool_adapters": [
    "adapter/agri/collar-sensor/v1"
  ],
  "permissions": {
    "mode": "750",
    "owner": "da_agri_ops_001",
    "group": "staff",
    "acl": [
      {
        "role": "qa",
        "access": "rx",
        "scope": "evaluation_only"
      },
      {
        "role": "auditor",
        "access": "rx",
        "scope": "log_records_only"
      },
      {
        "role": "user",
        "access": "x"
      }
    ]
  },
  "groups": {
    "staff": {
      "description": "Site managers and field operators with group-level access to agricultural operations.",
      "members": {
        "domain_roles": ["site_manager", "field_operator"]
      }
    }
  },
  "domain_roles": {
    "schema_version": "1.0",
    "roles": [
      {
        "role_id": "site_manager",
        "role_name": "Site Manager",
        "hierarchy_level": 1,
        "description": "On-site operational manager with full read/write/execute access to operations data.",
        "maps_to_system_role": "user",
        "default_access": "rwx",
        "may_assign_domain_roles": true,
        "max_assignable_level": 2
      },
      {
        "role_id": "field_operator",
        "role_name": "Field Operator",
        "hierarchy_level": 2,
        "description": "Field workers who execute operational procedures and log observations.",
        "maps_to_system_role": "user",
        "default_access": "rx",
        "may_assign_domain_roles": false,
        "scoped_capabilities": {
          "log_observations": true,
          "trigger_alerts": true,
          "modify_thresholds": false
        }
      },
      {
        "role_id": "observer",
        "role_name": "Observer",
        "hierarchy_level": 3,
        "description": "Read-only observers of agricultural operations data.",
        "maps_to_system_role": "user",
        "default_access": "r",
        "may_assign_domain_roles": false
      }
    ]
  },
  "execution_policy": {
    "deterministic_tools": [
      "adapter/agri/collar-sensor/v1"
    ],
    "precompiled_routes": {
      "invariant_handlers": {
        "within_tolerance": {
          "standing_order_id": "request_more_steps",
          "tool_adapter_id": "adapter/agri/collar-sensor/v1",
          "library_deps": ["environmental_sensors"]
        }
      },
      "standing_order_tools": {
        "request_more_steps": {
          "tool_chain": ["adapter/agri/collar-sensor/v1"],
          "library_deps": ["environmental_sensors"]
        }
      }
    }
  },
  "actor_types": [
    {
      "id": "sensor",
      "label": "Sensor",
      "description": "IoT device producing field-operations evidence through continuous environmental readings.",
      "evidence_sources": ["adapter/agri/collar-sensor/v1"],
      "groups": ["environmental_monitors"]
    },
    {
      "id": "operator",
      "label": "Farm Operator",
      "description": "Human operator making field decisions and recording observations.",
      "evidence_sources": [],
      "groups": ["field_crew"]
    }
  ],
  "actor_groups": {
    "environmental_monitors": {
      "description": "Sensors and IoT devices that produce continuous environmental readings.",
      "members": ["sensor"]
    },
    "field_crew": {
      "description": "Human operators and technicians who make field decisions and record observations.",
      "members": ["operator"]
    }
  },
  "group_libraries": [
    {
      "id": "environmental_sensors",
      "path": "domain-lib/sensors/environmental_sensors.py",
      "description": "Sensor normalization, tolerance checking, and batch aggregation for field-operations IoT devices.",
      "shared_with_modules": ["operations-level-1"]
    },
    {
      "id": "turn_interpretation",
      "path": "domain-lib/reference/turn-interpretation-spec-v1.md",
      "description": "Turn interpretation output schema — defines the JSON structure the SLM must emit when classifying operator intent.",
      "shared_with_modules": ["operations-level-1"]
    }
  ]
}
